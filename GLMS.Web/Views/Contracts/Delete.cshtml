@model Contract
@{ ViewData["Title"] = "Delete Contract"; }

<h2 class="text-danger"><i class="bi bi-trash me-2"></i>Delete Contract #@Model.ContractId</h2><hr />
<div class="alert alert-danger">This action cannot be undone.</div>
<dl class="row">
    <dt class="col-sm-3">Client</dt><dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        <span class="badge @(Model.Status == ContractStatus.Active ? "bg-success" :
            Model.Status == ContractStatus.Draft ? "bg-secondary" :
            Model.Status == ContractStatus.Expired ? "bg-danger" : "bg-warning text-dark")">
            @Model.Status
        </span>
    </dd>
    <dt class="col-sm-3">Period</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd") to @Model.EndDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Service Level</dt><dd class="col-sm-9">@Model.ServiceLevel</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="ContractId" />
    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
