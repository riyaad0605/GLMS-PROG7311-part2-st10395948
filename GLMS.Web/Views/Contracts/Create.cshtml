@model Contract
@{ ViewData["Title"] = "New Contract"; }

<div class="row justify-content-center">
<div class="col-md-7">
<h2><i class="bi bi-file-plus me-2"></i>New Contract</h2><hr />
<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="mb-3">
        <label asp-for="ClientId" class="form-label fw-semibold"></label>
        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select">
            <option value="">-- Select Client --</option>
        </select>
        <span asp-validation-for="ClientId" class="text-danger small"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="StartDate" class="form-label fw-semibold"></label>
            <input asp-for="StartDate" class="form-control" type="date" />
            <span asp-validation-for="StartDate" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="EndDate" class="form-label fw-semibold"></label>
            <input asp-for="EndDate" class="form-control" type="date" />
            <span asp-validation-for="EndDate" class="text-danger small"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Status" class="form-label fw-semibold"></label>
            <select asp-for="Status" class="form-select"
                    asp-items="Html.GetEnumSelectList<ContractStatus>()"></select>
            <span asp-validation-for="Status" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="ServiceLevel" class="form-label fw-semibold"></label>
            <select asp-for="ServiceLevel" class="form-select">
                <option value="">-- Select Level --</option>
                <option value="Basic">Basic</option>
                <option value="Standard">Standard</option>
                <option value="Premium">Premium</option>
                <option value="Enterprise">Enterprise</option>
            </select>
            <span asp-validation-for="ServiceLevel" class="text-danger small"></span>
        </div>
    </div>

    <div class="mb-4">
        <label for="signedAgreement" class="form-label fw-semibold">
            Signed Agreement (PDF, optional)
        </label>
        <input type="file" name="signedAgreement" id="signedAgreement"
               class="form-control" accept=".pdf" />
        <div class="form-text">Max 10 MB. PDF only.</div>
    </div>

    <button type="submit" class="btn btn-primary"><i class="bi bi-check me-1"></i>Create Contract</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
</div></div>
