@model ServiceRequest
@{ ViewData["Title"] = $"Request #{Model.ServiceRequestId}"; }

<h2><i class="bi bi-tools me-2"></i>Service Request #@Model.ServiceRequestId</h2><hr />
<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Contract</dt>
            <dd class="col-sm-8">
                <a asp-controller="Contracts" asp-action="Details"
                   asp-route-id="@Model.ContractId">Contract #@Model.ContractId</a>
            </dd>
            <dt class="col-sm-4">Client</dt>
            <dd class="col-sm-8 fw-semibold">@Model.Contract?.Client?.Name</dd>
            <dt class="col-sm-4">Description</dt>
            <dd class="col-sm-8">@Model.Description</dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8"><span class="badge bg-info text-dark">@Model.Status</span></dd>
            <dt class="col-sm-4">Date Created</dt>
            <dd class="col-sm-8">@Model.DateCreated.ToString("dd MMM yyyy HH:mm")</dd>
        </dl>
    </div>
    <div class="col-md-6">
        <div class="card bg-light">
            <div class="card-header fw-semibold"><i class="bi bi-currency-exchange me-2"></i>Costs</div>
            <div class="card-body">
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted">Original (USD)</span>
                    <span class="fw-bold">$ @Model.CostUsd.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted">Converted (ZAR)</span>
                    <span class="fw-bold text-success fs-5">R @Model.CostZar.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Delete" asp-route-id="@Model.ServiceRequestId" class="btn btn-danger mt-3">
        <i class="bi bi-trash me-1"></i>Delete
    </a>
}
<a asp-action="Index" class="btn btn-secondary mt-3 ms-2">
    <i class="bi bi-arrow-left me-1"></i>Back to List
</a>
