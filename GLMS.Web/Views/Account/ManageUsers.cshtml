@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Manage Users";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people-fill me-2"></i>Manage Users</h2>
    <a asp-action="Register" class="btn btn-success">
        <i class="bi bi-person-plus me-1"></i>Create New User
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Email Confirmed</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var roles = userRoles != null && userRoles.ContainsKey(user.Id)
                        ? userRoles[user.Id] : new List<string>();

                    <tr>
                        <td>
                            <i class="bi bi-person-circle me-2 text-muted"></i>@user.Email
                        </td>
                        <td>
                            @foreach (var role in roles)
                            {
                                <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary")">@role</span>
                            }
                        </td>
                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="badge bg-success"><i class="bi bi-check"></i> Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
