@model IEnumerable<Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2"></i>Clients</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Client</a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th><th>Contact Details</th><th>Region</th><th>Contracts</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="fw-semibold">@c.Name</td>
                        <td>@c.ContactDetails</td>
                        <td><span class="badge bg-secondary">@c.Region</span></td>
                        <td>@c.Contracts.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@c.ClientId" class="btn btn-sm btn-outline-info">Details</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@c.ClientId" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@c.ClientId" class="btn btn-sm btn-outline-danger">Delete</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
