@model Client
@{ ViewData["Title"] = "Add Client"; }

<div class="row justify-content-center">
<div class="col-md-6">
<h2><i class="bi bi-person-plus me-2"></i>Add Client</h2><hr />
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label fw-semibold"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ContactDetails" class="form-label fw-semibold"></label>
        <textarea asp-for="ContactDetails" class="form-control" rows="2" placeholder="email@domain.com | +27 11 000 0000"></textarea>
        <div class="form-text">Separate multiple details with a pipe ( | )</div>
        <span asp-validation-for="ContactDetails" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="Region" class="form-label fw-semibold"></label>
        <input asp-for="Region" class="form-control" />
        <span asp-validation-for="Region" class="text-danger small"></span>
    </div>
    <button type="submit" class="btn btn-primary"><i class="bi bi-check me-1"></i>Create</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
</div></div>
