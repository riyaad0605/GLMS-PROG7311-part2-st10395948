@model Client
@{ ViewData["Title"] = "Delete Client"; }

<h2><i class="bi bi-trash me-2 text-danger"></i>Delete Client</h2><hr />
<div class="alert alert-danger">Are you sure you want to delete <strong>@Model.Name</strong>?</div>
<dl class="row">
    <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">Region</dt><dd class="col-sm-9">@Model.Region</dd>
    <dt class="col-sm-3">Contact</dt><dd class="col-sm-9">@Model.ContactDetails</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="ClientId" />
    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
