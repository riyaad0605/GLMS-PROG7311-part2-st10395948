@model Client
@{ ViewData["Title"] = "Edit Client"; }

<div class="row justify-content-center">
<div class="col-md-6">
<h2><i class="bi bi-pencil me-2"></i>Edit Client</h2><hr />
<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <input type="hidden" asp-for="ClientId" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label fw-semibold"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ContactDetails" class="form-label fw-semibold"></label>
        <textarea asp-for="ContactDetails" class="form-control" rows="2"></textarea>
        <span asp-validation-for="ContactDetails" class="text-danger small"></span>
    </div>
    <div class="mb-4">
        <label asp-for="Region" class="form-label fw-semibold"></label>
        <input asp-for="Region" class="form-control" />
        <span asp-validation-for="Region" class="text-danger small"></span>
    </div>
    <button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
</div></div>
