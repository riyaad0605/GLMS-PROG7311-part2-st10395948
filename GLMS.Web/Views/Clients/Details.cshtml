@model Client
@{ ViewData["Title"] = "Client Details"; }

<h2><i class="bi bi-person me-2"></i>@Model.Name</h2><hr />
<dl class="row">
    <dt class="col-sm-3">Contact Details</dt>
    <dd class="col-sm-9">@Model.ContactDetails</dd>
    <dt class="col-sm-3">Region</dt>
    <dd class="col-sm-9"><span class="badge bg-secondary">@Model.Region</span></dd>
    <dt class="col-sm-3">Total Contracts</dt>
    <dd class="col-sm-9">@Model.Contracts.Count</dd>
</dl>

@if (Model.Contracts.Any())
{
    <h5 class="mt-3">Contracts</h5>
    <table class="table table-sm table-bordered">
        <thead class="table-secondary">
            <tr><th>#</th><th>Start Date</th><th>End Date</th><th>Status</th><th>Service Level</th></tr>
        </thead>
        <tbody>
            @foreach (var ct in Model.Contracts)
            {
                <tr>
                    <td>@ct.ContractId</td>
                    <td>@ct.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@ct.EndDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <span class="badge @(ct.Status == ContractStatus.Active ? "bg-success" :
                            ct.Status == ContractStatus.Draft ? "bg-secondary" :
                            ct.Status == ContractStatus.Expired ? "bg-danger" : "bg-warning text-dark")">
                            @ct.Status
                        </span>
                    </td>
                    <td>@ct.ServiceLevel</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (User.IsInRole("Admin"))
{
    <a asp-action="Edit" asp-route-id="@Model.ClientId" class="btn btn-warning">Edit</a>
}
<a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
